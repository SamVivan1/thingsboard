# ThingsBoard Configuration - Copy to .env and fill with actual values
# DO NOT commit .env file to version control for security reasons

# Server Configuration
THINGSBOARD_SERVER=thingsboard.cloud

# Device Configuration
DEVICE_ID=your_device_id_here
# Format: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Authentication - Choose one based on operation:

# API Key (for reading data and managing attributes - praktikum15 & praktikum17)
API_KEY=your_api_key_here
# Format: tb_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Access Token (for sending telemetry data - praktikum16)
ACCESS_TOKEN=your_access_token_here
# Format: xxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Request settings
REQUEST_TIMEOUT=10
